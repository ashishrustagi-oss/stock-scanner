# Ashish Capital — Local Credentials Template
# Copy this file to .env.local and fill in your real values
# .env.local is in .gitignore and will NEVER be committed to git
#
# HOW TO USE:
# 1. Copy this file: copy .env.local.template .env.local
# 2. Fill in your real values below (remove the placeholder text)
# 3. Save .env.local — it stays on your machine only

# M-stock credentials
MSTOCK_API_KEY=your_api_key_here
MSTOCK_USER_ID=your_client_id_here
MSTOCK_PASSWORD=your_password_here
MSTOCK_TOTP_SECRET=your_totp_secret_here

# Telegram (same values as your GitHub secrets)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

